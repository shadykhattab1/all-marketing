generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id           String   @id @default(cuid())
  sessionId    String
  brandName    String
  brandProfile Json
  content      Json?
  reels        Json?
  status       String   @default("draft")
  shareToken   String?  @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
}
